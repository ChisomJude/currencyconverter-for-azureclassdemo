# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit real secrets.

# Port the Flask dev server binds to (ignored by gunicorn in Docker, which
# is hardcoded to 8000 in the Dockerfile CMD).
PORT=8000

# Set to "false" to disable Flask's debug/auto-reload mode.
FLASK_DEBUG=true

# Override the exchange-rate API base URL if you switch providers.
EXCHANGE_API_BASE=https://open.er-api.com/v6/latest

# Day 3: paste your Application Insights connection string here to enable
# request + dependency tracking. Leave blank for local development.
APPLICATIONINSIGHTS_CONNECTION_STRING=
